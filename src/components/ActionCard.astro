---
interface Props {
  href: string;
  title: string;
  subtitle?: string;
  caption?: string;
  ancillaryHref?: string;
  ancillaryText?: string;
}

const { href, title, subtitle, caption, ancillaryHref, ancillaryText } = Astro.props;
---

<div class="flex flex-col rounded-xl border border-zinc-200 transition-all hover:border-blue-400 hover:bg-blue-50/50 hover:shadow-sm dark:border-zinc-700 dark:hover:border-blue-500 dark:hover:bg-blue-950/20">
  <a
    href={href}
    class="group flex items-center gap-4 p-5 no-underline"
  >
    <span class="shrink-0 text-3xl font-black text-blue-500 transition-transform group-hover:translate-x-1">→</span>
    <div>
      <p class="font-semibold leading-tight text-zinc-800 dark:text-zinc-200">{title}</p>
      {subtitle && (
        <p class="mt-1 text-sm text-blue-600 dark:text-blue-400">{subtitle}</p>
      )}
      {caption && (
        <p class="mt-1 text-xs text-zinc-600 dark:text-zinc-300" set:html={caption} />
      )}
    </div>
  </a>
  {ancillaryHref && ancillaryText && (
    <div class="border-t border-zinc-200 px-5 py-2 pl-[4.125rem] dark:border-zinc-700">
      <a href={ancillaryHref} class="text-xs text-zinc-500 hover:text-blue-600 dark:text-zinc-400 dark:hover:text-blue-400">
        {ancillaryText}
      </a>
    </div>
  )}
</div>
