---
interface Props {
  src: string;
  alt?: string;
  width?: string;
  height?: string;
}
const { src, alt, width = "100%", height = "500px" } = Astro.props;
---

<model-viewer
  class="my-6 overflow-hidden rounded-lg bg-zinc-300"
  style={`width: ${width}; height: ${height};`}
  alt={alt}
  src={src}
  camera-controls
  auto-rotate
  rotation-per-second="20deg"
  interaction-prompt-threshold="6000"
  orientation="270deg 0deg 0deg"></model-viewer>
<script>
  import "@google/model-viewer";
</script>
