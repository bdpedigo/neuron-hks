---
import SubPageLayout from "../layouts/SubPageLayout.astro";
import Notebook from "../components/Notebook.astro";

const baseUrl = import.meta.env.BASE_URL;
const prefix = baseUrl.endsWith("/") ? baseUrl : baseUrl + "/";
---

<SubPageLayout
  title="Programmatic Access — MICrONS HKS Predictions"
  description="How to programmatically access the MICrONS postsynaptic target predictions produced by the HKS pipeline."
  mainClass="max-w-3xl mx-auto px-6"
>
  <Notebook src="src/generated/programmatic-access.html" downloadHref={`${prefix}programmatic_access.ipynb`} />
</SubPageLayout>
